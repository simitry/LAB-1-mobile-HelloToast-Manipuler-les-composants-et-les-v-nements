<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/counter_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="@string/counter_title"
        android:textColor="@color/ink_soft"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/counter_value"
        android:layout_width="120dp"
        android:layout_height="96dp"
        android:layout_marginBottom="28dp"
        android:gravity="center"
        android:text="@string/zero"
        android:textColor="@color/ink"
        android:textSize="44sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/toast_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:text="@string/toast_button" />

    <Button
        android:id="@+id/count_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/count_button" />

</LinearLayout>
